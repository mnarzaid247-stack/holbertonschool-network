#!/usr/bin/env bash
# Configures localhost and facebook.com IP addresses.

# Update localhost safely without using in-place file replacement
sed 's/127\.0\.0\.1/127.0.0.2/g' /etc/hosts | sudo tee /etc/hosts > /dev/null

# Append the facebook.com routing rule
echo "8.8.8.8 facebook.com" | sudo tee -a /etc/hosts > /dev/null